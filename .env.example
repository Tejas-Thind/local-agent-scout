# Copy to .env and fill in. .env is gitignored.

# Frontier model (teacher + comparison). Get a key at console.anthropic.com
ANTHROPIC_API_KEY=

# Which model the harness runs. Swap this to compare local vs frontier.
#   local:    qwen3.5:9b        (via Ollama)
#   frontier: claude            (via Anthropic API)
SCOUT_MODEL=qwen3.5:9b

# Ollama endpoint (default local install)
OLLAMA_HOST=http://127.0.0.1:11434

# Frontier model id used when SCOUT_MODEL=claude
ANTHROPIC_MODEL=claude-opus-4-8
